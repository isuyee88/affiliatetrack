{
  "name": "affiliatetrack",
  "version": "1.0.0",
  "description": "Affiliate traffic tracking system on Cloudflare Workers + D1 + Durable Objects",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:production": "wrangler deploy --env production",
    "deploy:staging": "wrangler deploy --env staging",
    "db:init": "wrangler d1 execute affiliatetrack-db --file=./scripts/schema.sql",
    "db:migrate": "wrangler d1 migrations apply affiliatetrack-db",
    "db:seed": "wrangler d1 execute affiliatetrack-db --file=./scripts/seed.sql",
    "build": "npm run build:frontend && npm run build:worker",
    "build:worker": "esbuild src/worker.ts --bundle --outfile=dist/worker.js --format=esm --target=es2022",
    "build:frontend": "cd frontend && npm run build",
    "test": "vitest",
    "test:unit": "vitest run --dir tests/unit",
    "test:integration": "vitest run --dir tests/integration",
    "test:e2e": "playwright test --config=tests/e2e/playwright.config.ts",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src frontend/src --ext .ts,.tsx",
    "lint:fix": "eslint src frontend/src --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"frontend/src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "hono": "^4.0.0",
    "zod": "^3.22.0",
    "jose": "^5.2.0",
    "bcryptjs": "^2.4.3",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240117.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/uuid": "^9.0.7",
    "typescript": "^5.3.0",
    "wrangler": "^3.24.0",
    "esbuild": "^0.20.0",
    "vitest": "^1.2.0",
    "@vitest/coverage-v8": "^1.2.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "prettier": "^3.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "affiliate",
    "tracking",
    "cloudflare-workers",
    "d1",
    "durable-objects"
  ],
  "author": "AffiliateTrack Team",
  "license": "MIT"
}
